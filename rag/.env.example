# .env.example — copy to .env and fill in your values
# All variables have safe defaults; only API keys must be provided for real providers.

# ──────────────────────────────────────────────────────────── Server
HOST=0.0.0.0
PORT=8000
ENV=dev                        # dev | prod

# ──────────────────────────────────────────────────────────── Corpus
DATA_DIR=./data                # Local directory containing PDF/HTML/TXT sources

# ──────────────────────────────────────────────────────────── Vector DB
VECTOR_DB=chroma               # Only "chroma" is planned for now
CHROMA_DIR=./db_chroma         # Full corpus index (production)
# CHROMA_DIR=./db_chroma_test  # Uncomment to use the lightweight test index (single document)

# ──────────────────────────────────────────────────────────── LLM
LLM_PROVIDER=mock              # mock | gemini | groq | local
GOOGLE_API_KEY=                # Required when LLM_PROVIDER=gemini
GROQ_API_KEY=                  # Required when LLM_PROVIDER=groq

# ──────────────────────────────────────────────────────────── Embeddings
EMBEDDINGS_PROVIDER=local      # "local" uses sentence-transformers (no API key needed)
EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ──────────────────────────────────────────────────────────── Retrieval
RETRIEVAL_STRATEGY=mmr         # mmr | similarity
                               #   mmr        — Maximal Marginal Relevance: balances relevance
                               #                and diversity, reducing redundant chunks.
                               #   similarity — Plain cosine similarity (original behaviour).
MMR_FETCH_K=10                 # Candidate pool size for MMR re-ranking.
                               # The retriever fetches this many docs first, then re-ranks
                               # them to return k final results. Higher = more diversity
                               # coverage at a small latency cost.
MMR_LAMBDA=0.5                 # MMR lambda (0.0 = max diversity, 1.0 = max relevance).
                               # 0.5 balances both objectives.
