@prefix : <http://example.org/contratos#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:OntologiaContratos a owl:Ontology ;
    rdfs:label "Ontología de contratos, empleo y prestación de servicios"@es .

#################################################################
# Clases
#################################################################

:Persona a owl:Class ;
    rdfs:label "Persona natural o jurídica"@es .

:Contratante a owl:Class ;
    rdfs:subClassOf :Persona ;
    rdfs:label "Contratante"@es .

:Contratista a owl:Class ;
    rdfs:subClassOf :Persona ,
        [ a owl:Restriction ;
          owl:onProperty :tieneContrato ;
          owl:someValuesFrom :ContratoPrestacionServicios
        ] ;
    rdfs:label "Contratista"@es .

:Empleador a owl:Class ;
    rdfs:subClassOf :Contratante ,
        [ a owl:Restriction ;
          owl:onProperty :empleaA ;
          owl:allValuesFrom :Empleado
        ] ;
    rdfs:label "Empleador"@es .

:Empleado a owl:Class ;
    rdfs:subClassOf :Persona ,
        [ a owl:Restriction ;
          owl:onProperty :tieneContrato ;
          owl:someValuesFrom :ContratoLaboral
        ] ;
    rdfs:label "Empleado"@es .

:Contrato a owl:Class ;
    rdfs:label "Contrato"@es .

:ContratoLaboral a owl:Class ;
    rdfs:subClassOf :Contrato ,
        [ a owl:Restriction ;
          owl:onProperty :contratoAsociaEmpleado ;
          owl:cardinality "1"^^xsd:nonNegativeInteger
        ],
        [ a owl:Restriction ;
          owl:onProperty :contratoAsociaEmpleador ;
          owl:cardinality "1"^^xsd:nonNegativeInteger
        ] ;
    rdfs:label "Contrato laboral"@es .

:ContratoPrestacionServicios a owl:Class ;
    rdfs:subClassOf :Contrato ,
        [ a owl:Restriction ;
          owl:onProperty :contratoAsociaContratista ;
          owl:allValuesFrom :Contratista
        ] ;
    rdfs:label "Contrato de prestación de servicios"@es .

:Puesto a owl:Class ;
    rdfs:label "Puesto"@es .

:Salario a owl:Class ;
    rdfs:label "Salario"@es .

:Departamento a owl:Class ;
    rdfs:label "Departamento"@es .

:JornadaLaboral a owl:Class ;
    rdfs:label "Jornada laboral"@es .

:Beneficio a owl:Class ;
    rdfs:label "Beneficio"@es .

:TrabajadorVinculado a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            :Empleado
            [ a owl:Restriction ;
              owl:onProperty :tieneContrato ;
              owl:someValuesFrom :ContratoLaboral
            ]
        )
    ] ;
    rdfs:label "Trabajador vinculado"@es .

#################################################################
# Clases disjuntas
#################################################################

:Empleado owl:disjointWith :Empleador .
:ContratoLaboral owl:disjointWith :ContratoPrestacionServicios .
:Contratista owl:disjointWith :Empleado .

#################################################################
# Propiedades de objeto
#################################################################

:tieneContrato a owl:ObjectProperty ;
    rdfs:domain :Persona ;
    rdfs:range :Contrato ;
    rdfs:label "tiene contrato"@es .

:contrataA a owl:ObjectProperty ;
    rdfs:domain :Contratante ;
    rdfs:range :Persona ;
    owl:inverseOf :esContratadoPor ;
    rdfs:label "contrata a"@es .

:esContratadoPor a owl:ObjectProperty ;
    rdfs:domain :Persona ;
    rdfs:range :Contratante ;
    rdfs:label "es contratado por"@es .

:empleaA a owl:ObjectProperty ;
    rdfs:subPropertyOf :contrataA ;
    rdfs:domain :Empleador ;
    rdfs:range :Empleado ;
    owl:inverseOf :esEmpleadoDe ;
    rdfs:label "emplea a"@es .

:esEmpleadoDe a owl:ObjectProperty ;
    rdfs:subPropertyOf :esContratadoPor ;
    rdfs:domain :Empleado ;
    rdfs:range :Empleador ;
    rdfs:label "es empleado de"@es .

:asignaPuesto a owl:ObjectProperty ;
    rdfs:domain :Empleador ;
    rdfs:range :Puesto ;
    rdfs:label "asigna puesto"@es .

:ocupaPuesto a owl:ObjectProperty ;
    rdfs:domain :Empleado ;
    rdfs:range :Puesto ;
    rdfs:label "ocupa puesto"@es .

:perteneceADepartamento a owl:ObjectProperty ;
    rdfs:domain :Empleado ;
    rdfs:range :Departamento ;
    rdfs:label "pertenece a departamento"@es .

:tieneSalario a owl:ObjectProperty ;
    rdfs:domain :Empleado ;
    rdfs:range :Salario ;
    rdfs:label "tiene salario"@es .

:tieneJornada a owl:ObjectProperty ;
    rdfs:domain :Empleado ;
    rdfs:range :JornadaLaboral ;
    rdfs:label "tiene jornada"@es .

:ofreceBeneficio a owl:ObjectProperty ;
    rdfs:domain :Empleador ;
    rdfs:range :Beneficio ;
    rdfs:label "ofrece beneficio"@es .

:recibeBeneficio a owl:ObjectProperty ;
    rdfs:domain :Empleado ;
    rdfs:range :Beneficio ;
    rdfs:label "recibe beneficio"@es .

:contratoAsociaEmpleado a owl:ObjectProperty ;
    rdfs:domain :ContratoLaboral ;
    rdfs:range :Empleado ;
    rdfs:label "contrato asocia empleado"@es .

:contratoAsociaEmpleador a owl:ObjectProperty ;
    rdfs:domain :ContratoLaboral ;
    rdfs:range :Empleador ;
    rdfs:label "contrato asocia empleador"@es .

:contratoAsociaContratista a owl:ObjectProperty ;
    rdfs:domain :ContratoPrestacionServicios ;
    rdfs:range :Contratista ;
    rdfs:label "contrato asocia contratista"@es .

:contratoAsociaContratante a owl:ObjectProperty ;
    rdfs:domain :ContratoPrestacionServicios ;
    rdfs:range :Contratante ;
    rdfs:label "contrato asocia contratante"@es .

#################################################################
# Propiedades de datos
#################################################################

:nombreCompleto a owl:DatatypeProperty ;
    rdfs:domain :Persona ;
    rdfs:range xsd:string ;
    rdfs:label "nombre completo"@es .

:identificacion a owl:DatatypeProperty ;
    rdfs:domain :Persona ;
    rdfs:range xsd:string ;
    rdfs:label "identificación"@es .

:fechaInicio a owl:DatatypeProperty ;
    rdfs:domain :Contrato ;
    rdfs:range xsd:date ;
    rdfs:label "fecha de inicio"@es .

:fechaFin a owl:DatatypeProperty ;
    rdfs:domain :Contrato ;
    rdfs:range xsd:date ;
    rdfs:label "fecha de fin"@es .

:duracionMeses a owl:DatatypeProperty ;
    rdfs:domain :Contrato ;
    rdfs:range xsd:integer ;
    rdfs:label "duración en meses"@es .

:activo a owl:DatatypeProperty ;
    rdfs:domain :Contrato ;
    rdfs:range xsd:boolean ;
    rdfs:label "activo"@es .

:salarioBase a owl:DatatypeProperty ;
    rdfs:domain :Salario ;
    rdfs:range xsd:decimal ;
    rdfs:label "salario base"@es .

:moneda a owl:DatatypeProperty ;
    rdfs:domain :Salario ;
    rdfs:range xsd:string ;
    rdfs:label "moneda"@es .

:tituloPuesto a owl:DatatypeProperty ;
    rdfs:domain :Puesto ;
    rdfs:range xsd:string ;
    rdfs:label "título del puesto"@es .

:horasSemanales a owl:DatatypeProperty ;
    rdfs:domain :JornadaLaboral ;
    rdfs:range xsd:integer ;
    rdfs:label "horas semanales"@es .

:tipoBeneficio a owl:DatatypeProperty ;
    rdfs:domain :Beneficio ;
    rdfs:range xsd:string ;
    rdfs:label "tipo de beneficio"@es .

:nombreDepartamento a owl:DatatypeProperty ;
    rdfs:domain :Departamento ;
    rdfs:range xsd:string ;
    rdfs:label "nombre del departamento"@es .

